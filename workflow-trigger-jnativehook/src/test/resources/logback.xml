<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %red(%date{yyyy-MM-dd HH:mm:ss}) %highlight(%-5level) %replace(%blue(%X{module})){'^$',''}%red([%thread]) %boldBlue(%logger{50}[%L]) %cyan(%msg%n)
            </pattern>
        </encoder>
    </appender>

    <logger name="cc.pineclone.workflow.trigger.jnativehook.GestureTrigger" level="DEBUG"/>
<!--    <logger name="cc.pineclone.workflow.trigger.jnativehook.GestureTrigger$NeuMouseTrigger" level="OFF"/>-->
    <logger name="cc.pineclone.workflow.trigger.jnativehook.gesture.ClickGesture$MouseButtonClickGesture" level="DEBUG"/>

    <!-- 默认输出 -->
    <root level="DEBUG">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>